{
    "name": "notion-api-types",
    "version": "0.3.0",
    "description": "A typescript package template",
    "repository": "https://github.com/bkeys818/notion-api-types.git",
    "author": "Ben Keys (https://github.com/bkeys818)",
    "license": "MIT",
    "scripts": {
        "prepare": "husky install",
        "build": "rimraf types && tsc",
        "test": "yarn build && tsc -p tests.tsconfig.json",
        "write-tests": "ts-node -P ./.github/scripts/tsconfig.json ./.github/scripts/create-tests/index.ts"
    },
    "types": "types",
    "devDependencies": {
        "@tsconfig/recommended": "^1.0.1",
        "@types/node": "^17.0.8",
        "@types/node-fetch": "2.x",
        "@types/prettier": "^2.4.3",
        "@typescript-eslint/eslint-plugin": "^5.7.0",
        "@typescript-eslint/parser": "^5.7.0",
        "dotenv": "^11.0.0",
        "eslint": "^8.5.0",
        "eslint-config-prettier": "^8.3.0",
        "eslint-plugin-prettier": "^4.0.0",
        "husky": "^7.0.0",
        "lint-staged": ">=10",
        "markdownlint-cli": "^0.30.0",
        "node-fetch": "^2.6.6",
        "prettier": "^2.5.1",
        "rimraf": "^3.0.2",
        "ts-node": "^10.4.0",
        "typescript": "^4.5.4"
    },
    "lint-staged": {
        "*.ts": [
            "prettier -w",
            "eslint --cache"
        ],
        "*.md": [
            "prettier -w",
            "markdownlint"
        ],
        "*.{json,jsonc}": "prettier -w"
    }
}
